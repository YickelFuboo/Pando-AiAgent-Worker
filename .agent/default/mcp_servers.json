{
  "mcp_servers": [
    {
      "id": "github",
      "type": "sse",
      "endpoint": "https://mcp.example.com/github",
      "api_key_env": "GITHUB_TOKEN",
      "timeout_ms": 30000,
      "tools": [
        "search_repositories",
        "create_issue",
        "get_file"
      ]
    },
    {
      "id": "jira",
      "type": "sse",
      "endpoint": "https://mcp.example.com/jira",
      "api_key_env": "JIRA_API_TOKEN",
      "tools": [
        "search_issues",
        "create_issue"
      ]
    },
    {
      "id": "filesystem",
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/workspace"
      ],
      "tools": []
    }
  ]
}

